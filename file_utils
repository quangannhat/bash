#!/usr/bin/env bash

. ~/scripts/libs/log_utils

find_by_ext() {
    local dir="${1:-.}"
    local ext="${2:-}"
    local first=0

    if [[ -z "$ext" ]]; then
        log_error "Usage: find_by_ext <directory> <extension>"
        return 1
    fi

    local pattern="*.$ext"
    for file in "$dir"/$pattern; do
        if [[ -f "$file" ]]; then
            log_info "Found: $file"
            first=1
        fi
    done

    [[ $first -eq 1 ]]
}

batch_mv() {
    local src_dir="${1:-.}"
    local dest_dir="${2:-.}"
    local ext="${3:-*}"

    if [[ -z "$ext" || "$ext" == "*" ]]; then
        log_error "Usage: batch_mv <source_dir> <dest_dir> <extension>"
        return 1
    fi

    if [[ ! -d "$dest_dir" ]]; then
        mkdir -p "$dest_dir"
    fi

    local pattern="*.$ext"
    local count=0
    for file in "$src_dir"/$pattern; do
        if [[ -f "$file" ]]; then
            mv "$file" "$dest_dir/"
            ((count++))
        fi
    done

    log_info "Moved $count file(s)"
    [[ $count -gt 0 ]]
}

find_by_name() {
    local dir="${1:-.}"
    local pattern="${2:-}"

    if [[ -z "$pattern" ]]; then
        log_error "Usage: find_by_name <directory> <pattern>"
        return 1
    fi

    find "$dir" -iname "$pattern" -type f
}

file_count() {
    local dir="${1:-.}"
    local ext="${2:-}"

    local pattern
    if [[ -n "$ext" ]]; then
        pattern="*.$ext"
    else
        pattern="*"
    fi

    local count=0
    for file in "$dir"/$pattern; do
        [[ -f "$file" ]] && ((count++))
    done

    log_info "Found $count file(s)"
    echo "$count"
}

file_size() {
    local dir="${1:-.}"
    local ext="${2:-}"

    local pattern
    if [[ -n "$ext" ]]; then
        pattern="*.$ext"
    else
        pattern="*"
    fi

    local total=0
    for file in "$dir"/$pattern; do
        if [[ -f "$file" ]]; then
            local size
            size=$(stat -c%s "$file" 2>/dev/null) || size=0
            ((total+=size))
        fi
    done

    log_info "Total size: $total bytes"
    echo "$total"
}

backup_file() {
    local file="${1:-}"

    if [[ -z "$file" || ! -f "$file" ]]; then
        log_error "Usage: backup_file <file>"
        return 1
    fi

    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup="${file}.${timestamp}.bak"

    cp "$file" "$backup"
    log_success "Backed up: $backup"
}

ensure_dir() {
    local dir="${1:-}"

    if [[ -z "$dir" ]]; then
        log_error "Usage: ensure_dir <directory>"
        return 1
    fi

    if [[ ! -d "$dir" ]]; then
        mkdir -p "$dir"
        log_info "Created directory: $dir"
    fi
}

confirm() {
    local prompt="${1:-Are you sure?}"
    local response

    while true; do
        read -p "$prompt [y/n] " response
        case "$response" in
            y|Y) return 0 ;;
            n|N) return 1 ;;
        esac
    done
}

is_empty_dir() {
    local dir="${1:-.}"

    if [[ ! -d "$dir" ]]; then
        return 1
    fi

    [[ -z "$(ls -A "$dir" 2>/dev/null)" ]]
}

new_script() {
	local dir=${2:-.}
	local file_name=$1

	if [[ -z $1 ]]; then
		read -p "Enter file name: " file_name
	fi

	local file_path="$dir/$file_name"

	if [[ -f "$file_path" ]]; then
		log_error "Error: file already exists" 
		return 1
	fi

	touch "$file_path"
	echo '#!/usr/bin/env bash' > "$file_path"
	chmod +x "$file_path"
	log_success "Created: $file_path"
}

